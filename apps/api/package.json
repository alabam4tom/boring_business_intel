{
  "name": "api",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --dts",
    "start": "node dist/server.js",
    "lint": "eslint --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@repo/db": "workspace:*",
    "@repo/shared": "workspace:*",
    "better-auth": "^1.6.5",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.1.0",
    "pg-boss": "^10.3.1",
    "pino": "^9.6.0",
    "uuidv7": "^1.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "5.9.2",
    "vitest": "^3.2.1"
  }
}
